<h2 class="text-2xl font-bold text-gray-800 mt-10 mb-6 text-center">Your Allocations Summary</h2>

<div class="max-w-xl mx-auto bg-white shadow-md rounded-lg p-6 space-y-4">
  <ul class="space-y-2">
    <% @allocations.each do |allocation| %>
      <li class="flex justify-between items-center border-b pb-2 text-gray-700">
        <span class="font-medium"><%= allocation.project.name %></span>
        <span class="text-blue-600 font-semibold">$<%= allocation.amount %></span>
      </li>
    <% end %>
  </ul>

  <div class="text-center mt-6">
    <%= link_to "← Back", allocations_path,
          class: "inline-block bg-gray-100 hover:bg-gray-200 text-gray-800 px-4 py-2 rounded-md shadow-sm transition duration-200 text-sm font-medium" %>
  </div>
</div>
