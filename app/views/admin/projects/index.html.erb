<h2 class="text-2xl font-bold text-gray-800 mb-6 mt-10 text-center">Admin Allocation Summary</h2>

<div class="max-w-3xl mx-auto bg-white shadow-md rounded-lg p-6">
  <table class="w-full text-left text-gray-700 border-separate border-spacing-y-2">
    <thead>
      <tr class="text-sm font-semibold text-gray-500 uppercase border-b">
        <th class="px-4 py-2">Project</th>
        <th class="px-4 py-2">Total Allocated ($)</th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr class="bg-gray-50 hover:bg-gray-100 transition">
          <td class="px-4 py-2 font-medium"><%= project.name %></td>
          <td class="px-4 py-2 text-blue-600 font-semibold"><%= project.total_allocated %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="text-center mt-6">
    <%= link_to "← Back to Allocation Form", allocations_path,
          class: "inline-block bg-gray-100 hover:bg-gray-200 text-gray-800 px-4 py-2 rounded-md shadow-sm transition duration-200 text-sm font-medium" %>
  </div>
</div>
